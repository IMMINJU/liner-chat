# Neon Postgres connection string
# https://neon.com/ → 프로젝트 생성 후 connection string 복사
DATABASE_URL=

# Spotify Developer App (로그인 없음 — Client Credentials 전용)
# https://developer.spotify.com/dashboard → 앱 생성 후 Client ID/Secret 복사.
# 로그인을 쓰지 않으므로 redirect URI 등록은 필요 없다. 검증·시드 검색은
# 앱 자체 토큰(client_credentials)으로 공개 카탈로그 엔드포인트만 호출한다.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm API (시드 컨텍스트의 트랙/아티스트 태그 보조)
# https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Anthropic API (의도 분류 = Haiku, 친족 추천 = Sonnet)
ANTHROPIC_API_KEY=
