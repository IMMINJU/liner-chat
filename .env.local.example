# Neon Postgres connection string
# https://neon.com/ → 프로젝트 생성 후 connection string 복사
DATABASE_URL=

# Spotify Developer App
# https://developer.spotify.com/dashboard → 앱 생성 후 redirect URI를 아래와 동일하게 등록
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Last.fm API (모드 1 장르 분류 보조)
# https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Anthropic API (의도 분류 = Haiku, 친족 추천 = Sonnet)
ANTHROPIC_API_KEY=

# iron-session 암호화 키. 최소 32바이트 임의 문자열.
# 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
